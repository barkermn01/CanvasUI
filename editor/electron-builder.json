{
    "appId": "com.canvasui.stream-manager",
    "productName": "CanvasUI Stream Manager",
    "directories": {
        "output": "dist"
    },
    "files": [
        "src/**/*",
        "node_modules/**/*",
        "package.json"
    ],
    "extraResources": [
        {
            "from": "build-www",
            "to": "www",
            "filter": ["**/*"]
        },
        {
            "from": "../tools/ca.json",
            "to": "ca.json"
        },
        {
            "from": "../tools/crl.json",
            "to": "crl.json"
        }
    ],
    "win": {
        "target": [
            {
                "target": "nsis",
                "arch": ["x64"]
            }
        ],
        "icon": "../icon.png",
        "executableName": "canvasui"
    },
    "mac": {
        "target": ["dmg"],
        "icon": "../icon.png",
        "category": "public.app-category.video"
    },
    "linux": {
        "target": ["AppImage", "deb"],
        "icon": "../icon.png",
        "category": "AudioVideo",
        "executableName": "canvasui"
    },
    "nsis": {
        "oneClick": false,
        "allowToChangeInstallationDirectory": true,
        "installerIcon": "icon.ico",
        "uninstallerIcon": "icon.ico",
        "createDesktopShortcut": true,
        "createStartMenuShortcut": true,
        "shortcutName": "CanvasUI Stream Manager",
        "artifactName": "CanvasUI Setup ${version}.${env.BUILD_NUMBER}.exe",
        "perMachine": false,
        "include": "installer.nsh"
    }
}
