{
    "name": "image",
    "displayName": "Image",
    "icon": "🖼️",
    "type": "canvas",
    "configKey": "image",
    "entrypoint": "image.js",
    "editorClass": "ImageDisplay",
    "hasSettings": true,
    "allowMultiple": true,
    "description": "Static image overlay",
    "gradient": { "from": "rgba(34, 197, 94, 0.08)", "to": "rgba(34, 197, 94, 0.25)" },
    "schema": {
        "_type": {
            "src": "string",
            "opacity": "number",
            "objectFit": { "type": "select", "options": ["contain", "cover", "fill", "none"] }
        },
        "_labels": {
            "src": { "label": "Source", "tooltip": "Path to the image file (e.g. /media/overlay.png)" },
            "opacity": { "label": "Opacity", "tooltip": "Transparency level (0 = invisible, 1 = fully visible)" },
            "objectFit": { "label": "Fit Mode", "tooltip": "How the image fits within its area" }
        }
    }
}
