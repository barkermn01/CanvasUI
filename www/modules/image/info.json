{
    "name": "image",
    "displayName": "Image",
    "icon": "🖼️",
    "type": "canvas",
    "configKey": "image",
    "entrypoint": "image.js",
    "editorClass": "ImageDisplay",
    "hasSettings": false,
    "allowMultiple": true,
    "description": "Static image overlay",
    "gradient": {
        "from": "rgba(34, 197, 94, 0.08)",
        "to": "rgba(34, 197, 94, 0.25)"
    },
    "properties": {
        "src": {
            "type": "media",
            "label": "Source",
            "mediaType": "image"
        },
        "opacity": {
            "type": "range",
            "label": "Opacity",
            "min": 0,
            "max": 1,
            "step": 0.1,
            "default": 1
        },
        "objectFit": {
            "type": "select",
            "label": "Fit Mode",
            "options": [
                "contain",
                "cover",
                "fill",
                "none"
            ],
            "default": "contain"
        }
    },
    "version": "1.4.2",
    "builtForVersion": "1.4.2"
}
