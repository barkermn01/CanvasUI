{
    "name": "chat",
    "displayName": "Chat",
    "icon": "💬",
    "type": "canvas",
    "configKey": "chat",
    "entrypoint": "chat.js",
    "hasSettings": true,
    "allowMultiple": false,
    "description": "Displays Twitch/YouTube chat messages",
    "gradient": { "from": "rgba(59, 130, 246, 0.08)", "to": "rgba(59, 130, 246, 0.25)" },
    "schema": {
        "_type": {
            "BeforeCanvas": "bool",
            "hideBots": "bool"
        },
        "_labels": {
            "BeforeCanvas": { "label": "Behind Canvas", "tooltip": "Render chat behind the canvas layer" },
            "hideBots": { "label": "Hide Bots", "tooltip": "Hide messages from bot accounts listed in the Bots tab" }
        },
        "_item_type": {
            "ExtendedEmotesServices": "object",
            "MessageArea": "css",
            "AutoHide": "object",
            "platforms": "object",
            "ChatBoxes": "object",
            "RemovedMessage": "object"
        },
        "ExtendedEmotesServices": {
            "_type": {
                "BTTV": "bool",
                "FFZ": "bool"
            },
            "_labels": {
                "BTTV": { "label": "BetterTTV", "tooltip": "Enable BetterTTV emotes" },
                "FFZ": { "label": "FrankerFaceZ", "tooltip": "Enable FrankerFaceZ emotes" }
            }
        },
        "AutoHide": {
            "_type": {
                "enabled": "bool",
                "time": "number",
                "animation": { "type": "select", "options": ["slide", "fade"] },
                "direction": { "type": "select", "options": ["left", "right"] }
            },
            "_labels": {
                "enabled": { "label": "Enabled", "tooltip": "Automatically hide messages after a set time" },
                "time": { "label": "Time (seconds)", "tooltip": "Seconds before a message starts to hide" },
                "animation": { "label": "Animation", "tooltip": "How messages disappear" },
                "direction": { "label": "Slide Direction", "tooltip": "Direction messages slide out (when animation is slide)" }
            }
        },
        "ChatBoxes": {
            "_type": {
                "ShowBadges": "bool",
                "ShowEmotes": "bool",
                "UserColon": "bool",
                "allowClipping": "bool",
                "NewMessages": { "type": "select", "options": ["below", "above"] },
                "position": { "type": "select", "options": ["top", "bottom"] }
            },
            "_labels": {
                "ShowBadges": { "label": "Show Badges", "tooltip": "Display user badges (sub, mod, etc.)" },
                "ShowEmotes": { "label": "Show Emotes", "tooltip": "Render emote images inline" },
                "UserColon": { "label": "Show Colon", "tooltip": "Show ':' after username" },
                "allowClipping": { "label": "Allow Clipping", "tooltip": "Allow messages to overflow the container" },
                "NewMessages": { "label": "New Messages", "tooltip": "Where new messages appear relative to existing ones" },
                "position": { "label": "Position", "tooltip": "Where chat starts from (top or bottom of area)" }
            },
            "_item_type": {
                "BadgeSettings": "object",
                "HideSpecificBadges": "object",
                "messageStyle": "css",
                "style": "css"
            },
            "BadgeSettings": {
                "_type": {
                    "width": "number",
                    "height": "number"
                },
                "_labels": {
                    "width": { "label": "Badge Width", "tooltip": "Badge image width in pixels" },
                    "height": { "label": "Badge Height", "tooltip": "Badge image height in pixels" }
                }
            }
        },
        "RemovedMessage": {
            "_type": {
                "hideMessage": "bool",
                "Text": "string",
                "color": "color",
                "italics": "bool",
                "bold": "bool"
            },
            "_labels": {
                "hideMessage": { "label": "Hide Entirely", "tooltip": "Remove the message completely instead of showing replacement text" },
                "Text": { "label": "Replacement Text", "tooltip": "Text shown in place of removed messages" },
                "color": { "label": "Text Color", "tooltip": "Color of the replacement text" },
                "italics": { "label": "Italic", "tooltip": "Render replacement text in italics" },
                "bold": { "label": "Bold", "tooltip": "Render replacement text in bold" }
            }
        }
    }
}
