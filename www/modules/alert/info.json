{
    "name": "alert",
    "displayName": "Alert",
    "icon": "🔔",
    "type": "canvas",
    "configKey": "alert",
    "entrypoint": "alert.js",
    "editorClass": "AlertModule",
    "hasSettings": false,
    "allowMultiple": true,
    "description": "Animated alert popups for follows, subs, raids, and custom events",
    "gradient": { "from": "rgba(245, 158, 11, 0.08)", "to": "rgba(245, 158, 11, 0.25)" },
    "properties": {
        "duration": {
            "type": "range",
            "label": "Display Duration (s)",
            "min": 1,
            "max": 30,
            "step": 0.5,
            "default": 5
        },
        "animationIn": {
            "type": "select",
            "label": "Animation In",
            "options": ["fade", "slide-down", "slide-up", "scale", "none"],
            "default": "scale"
        },
        "animationOut": {
            "type": "select",
            "label": "Animation Out",
            "options": ["fade", "slide-down", "slide-up", "scale", "none"],
            "default": "fade"
        },
        "animationSpeed": {
            "type": "range",
            "label": "Animation Speed (s)",
            "min": 0.1,
            "max": 2,
            "step": 0.1,
            "default": 0.3
        },
        "backgroundImage": {
            "type": "media",
            "label": "Background Image",
            "mediaType": "image"
        },
        "defaultImage": {
            "type": "media",
            "label": "Alert Image",
            "mediaType": "image"
        },
        "imageX": {
            "type": "number",
            "label": "Image X",
            "min": 0,
            "max": 2000,
            "default": 0
        },
        "imageY": {
            "type": "number",
            "label": "Image Y",
            "min": 0,
            "max": 2000,
            "default": 12
        },
        "imageMaxHeight": {
            "type": "range",
            "label": "Image Max Height (%)",
            "min": 10,
            "max": 100,
            "step": 5,
            "default": 50
        },
        "titleX": {
            "type": "number",
            "label": "Title X",
            "min": 0,
            "max": 2000,
            "default": 0
        },
        "titleY": {
            "type": "number",
            "label": "Title Y",
            "min": 0,
            "max": 2000,
            "default": 0
        },
        "titleAlign": {
            "type": "select",
            "label": "Title Align",
            "options": ["left", "center", "right"],
            "default": "center"
        },
        "fontSize": {
            "type": "range",
            "label": "Title Font Size",
            "min": 12,
            "max": 72,
            "step": 2,
            "default": 24
        },
        "fontFamily": {
            "type": "string",
            "label": "Font Family",
            "default": "sans-serif"
        },
        "textColor": {
            "type": "color",
            "label": "Title Color",
            "default": "#ffffff"
        },
        "messageX": {
            "type": "number",
            "label": "Message X",
            "min": 0,
            "max": 2000,
            "default": 0
        },
        "messageY": {
            "type": "number",
            "label": "Message Y",
            "min": 0,
            "max": 2000,
            "default": 0
        },
        "messageAlign": {
            "type": "select",
            "label": "Message Align",
            "options": ["left", "center", "right"],
            "default": "center"
        },
        "messageFontSize": {
            "type": "range",
            "label": "Message Font Size",
            "min": 10,
            "max": 48,
            "step": 1,
            "default": 18
        },
        "messageColor": {
            "type": "color",
            "label": "Message Color",
            "default": "#cccccc"
        },
        "backgroundColor": {
            "type": "color",
            "label": "Background Color",
            "default": "#1a1a2e"
        },
        "borderColor": {
            "type": "color",
            "label": "Border Color",
            "default": "#f59e0b"
        },
        "borderWidth": {
            "type": "range",
            "label": "Border Width",
            "min": 0,
            "max": 8,
            "step": 1,
            "default": 2
        },
        "borderRadius": {
            "type": "range",
            "label": "Border Radius",
            "min": 0,
            "max": 30,
            "step": 1,
            "default": 8
        }
    }
}
