{
    "name": "steeringwheel",
    "displayName": "Steering Wheel",
    "icon": "🎮",
    "type": "canvas",
    "configKey": "steeringwheel",
    "entrypoint": "steeringwheel.js",
    "editorClass": "SteeringWheel",
    "hasSettings": false,
    "allowMultiple": true,
    "description": "Displays a rotating steering wheel driven by a gamepad axis",
    "gradient": { "from": "rgba(99, 102, 241, 0.08)", "to": "rgba(99, 102, 241, 0.25)" },
    "properties": {
        "gamepadIndex": {
            "type": "gamepadDevice",
            "label": "Controller"
        },
        "axisIndex": {
            "type": "number",
            "label": "Axis Index",
            "min": 0,
            "max": 15,
            "default": 0
        },
        "maxRotation": {
            "type": "range",
            "label": "Max Rotation (°)",
            "min": 45,
            "max": 900,
            "step": 5,
            "default": 450
        },
        "rotationOffset": {
            "type": "range",
            "label": "Rotation Offset (°)",
            "min": -180,
            "max": 180,
            "step": 1,
            "default": 0
        },
        "invertAxis": {
            "type": "bool",
            "label": "Invert Axis",
            "default": false
        },
        "deadzone": {
            "type": "range",
            "label": "Deadzone",
            "min": 0,
            "max": 0.5,
            "step": 0.01,
            "default": 0.02
        },
        "wheelImage": {
            "type": "media",
            "label": "Wheel Image",
            "mediaType": "image"
        },
        "wheelColor": {
            "type": "color",
            "label": "Wheel Color",
            "default": "#ffffff"
        },
        "wheelThickness": {
            "type": "range",
            "label": "Wheel Thickness",
            "min": 2,
            "max": 20,
            "step": 1,
            "default": 6
        },
        "showAxisDebug": {
            "type": "bool",
            "label": "Show Axis Values",
            "default": false
        }
    }
}
