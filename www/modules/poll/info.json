{
    "name": "poll",
    "displayName": "Poll Display",
    "icon": "📋",
    "type": "canvas",
    "configKey": "poll",
    "entrypoint": "poll.js",
    "editorClass": "PollModule",
    "hasSettings": false,
    "allowMultiple": true,
    "description": "Displays active poll with live-updating vote bars",
    "gradient": {
        "from": "rgba(6, 182, 212, 0.08)",
        "to": "rgba(6, 182, 212, 0.25)"
    },
    "properties": {
        "fontSize": {
            "type": "range",
            "label": "Font Size",
            "min": 10,
            "max": 36,
            "step": 1,
            "default": 16
        },
        "backgroundImage": {
            "type": "media",
            "label": "Background Image",
            "mediaType": "image"
        },
        "barColor": {
            "type": "color",
            "label": "Bar Color",
            "default": "#06b6d4"
        },
        "backgroundColor": {
            "type": "color",
            "label": "Background",
            "default": "#1f2937"
        },
        "textColor": {
            "type": "color",
            "label": "Text Color",
            "default": "#ffffff"
        },
        "hideWhenInactive": {
            "type": "bool",
            "label": "Hide When No Poll",
            "default": true
        },
        "showPercentage": {
            "type": "bool",
            "label": "Show Percentage",
            "default": true
        }
    },
    "version": "1.5.0",
    "builtForVersion": "1.5.0"
}
