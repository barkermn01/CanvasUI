{
    "name": "audiovisualiser",
    "displayName": "Audio Visualiser",
    "icon": "🎵",
    "type": "canvas",
    "configKey": "AudioVisualiser",
    "entrypoint": "audiovisualiser.js",
    "hasSettings": true,
    "allowMultiple": true,
    "description": "Audio frequency visualisation bars",
    "gradient": { "from": "rgba(168, 85, 247, 0.08)", "to": "rgba(168, 85, 247, 0.25)" },
    "schema": {
        "_type": {
            "device": "audioDevice",
            "direction": {
                "type": "select",
                "options": ["left-right", "right-left", "top-down", "bottom-up"]
            },
            "mirrored": "bool",
            "barWidth": "number",
            "barHeight": "number",
            "barSpacing": "number",
            "backgroundColor": "string"
        },
        "_item_type": {
            "area": "css",
            "colors": "object"
        },
        "colors": {
            "_type": {
                "mode": {
                    "type": "select",
                    "options": ["levels", "gradient"]
                },
                "level1": { "type": "color", "showWhen": { "field": "mode", "value": "levels" } },
                "level2": { "type": "color", "showWhen": { "field": "mode", "value": "levels" } },
                "level3": { "type": "color", "showWhen": { "field": "mode", "value": "levels" } },
                "level4": { "type": "color", "showWhen": { "field": "mode", "value": "levels" } },
                "gradient": { "type": "gradient", "showWhen": { "field": "mode", "value": "gradient" } }
            }
        }
    }
}
