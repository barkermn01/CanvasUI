                },
                "Max": {
                    "label": "Maximum (seconds)",
                    "tooltip": "Longest time an emote stays on screen"
                }
            }
        },
        "Speed": {
            "_type": {
                "Min": "number",
                "Max": "number"
            },
            "_labels": {
                "Min": {
                    "label": "Minimum (px/s)",
                    "tooltip": "Slowest movement speed in pixels per second"
                },
                "Max": {
                    "label": "Maximum (px/s)",
                    "tooltip": "Fastest movement speed in pixels per second"
                }
            }
        }
    },
    "version": "1.5.0",
    "builtForVersion": "1.5.0"
