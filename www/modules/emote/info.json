{
    "name": "emote",
    "displayName": "Emotes",
    "icon": "😀",
    "type": "canvas",
    "configKey": "emote",
    "entrypoint": "emote.js",
    "editorClass": "Emote",
    "hasSettings": true,
    "allowMultiple": false,
    "description": "Bouncing emotes from chat",
    "gradient": {
        "from": "rgba(234, 179, 8, 0.08)",
        "to": "rgba(234, 179, 8, 0.25)"
    },
    "schema": {
