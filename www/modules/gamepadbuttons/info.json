{
    "name": "gamepadbuttons",
    "displayName": "Gamepad Button",
    "icon": "🔘",
    "type": "canvas",
    "configKey": "gamepadbuttons",
    "entrypoint": "gamepadbuttons.js",
    "editorClass": "GamepadButtons",
    "hasSettings": false,
    "allowMultiple": true,
    "description": "Displays a single controller button with idle/active images",
    "gradient": {
        "from": "rgba(236, 72, 153, 0.08)",
        "to": "rgba(236, 72, 153, 0.25)"
    },
    "properties": {
        "gamepadIndex": {
            "type": "gamepadDevice",
            "label": "Controller"
        },
        "buttonIndex": {
            "type": "gamepadButton",
            "label": "Button"
        },
        "idleImage": {
            "type": "media",
            "label": "Idle Image",
            "mediaType": "image"
        },
        "activeImage": {
            "type": "media",
            "label": "Active Image",
            "mediaType": "image"
        },
        "inactiveColor": {
            "type": "color",
            "label": "Inactive Color",
            "default": "#333333"
        },
        "activeColor": {
            "type": "color",
            "label": "Active Color",
            "default": "#ff4488"
        },
        "borderColor": {
            "type": "color",
            "label": "Border Color",
            "default": "#888888"
        },
        "showLabel": {
            "type": "bool",
            "label": "Show Button Number",
            "default": true
        }
    },
    "version": "1.5.0",
    "builtForVersion": "1.5.0"
}
